<UserControl
    x:Class="CanvasClient.Canvas.CollaborativeCanvasControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:win2d="using:Microsoft.Graphics.Canvas.UI.Xaml"
    mc:Ignorable="d">

    <Grid Background="Transparent">

        <!--
            Win2D CanvasControl: canvas GPU-accelerated (Direct2D), vẽ theo mô hình
            immediate-mode — mỗi lần Invalidate() sẽ gọi lại Draw một lần. Đây là lựa
            chọn hiệu năng cao hơn nhiều so với vẽ bằng hàng trăm, hàng ngàn phần tử
            Path dạng XAML khi số nét vẽ tích lũy lớn theo thời gian của một phiên cộng tác.
        -->
        <win2d:CanvasControl
            x:Name="DrawSurface"
            CreateResources="DrawSurface_CreateResources"
            Draw="DrawSurface_Draw"
            SizeChanged="DrawSurface_SizeChanged"
            PointerPressed="DrawSurface_PointerPressed"
            PointerMoved="DrawSurface_PointerMoved"
            PointerReleased="DrawSurface_PointerReleased"
            PointerExited="DrawSurface_PointerExited"
            PointerCanceled="DrawSurface_PointerCanceled" />

        <!--
            Lớp phủ đồng bộ. Vì Grid này có Background không trong suốt hoàn toàn,
            nó tự động hit-test và CHẶN pointer chạm tới DrawSurface bên dưới khi
            đang Visible — đây chính là phần "Gate UI-side" được yêu cầu trong tài
            liệu đề tài (chặn thao tác cho tới khi nhận đủ SyncCompletePacket).
        -->
        <Grid x:Name="SyncOverlay" Background="#CC1E1E1E">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12" Padding="24">
                <ProgressRing IsActive="True" Width="44" Height="44" HorizontalAlignment="Center" />
                <TextBlock
                    x:Name="SyncStatusText"
                    Text="Chưa kết nối tới máy chủ."
                    Foreground="White"
                    FontSize="14"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
